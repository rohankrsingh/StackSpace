{
  "name": "collabcode",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/socket-server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:socket\"",
    "dev:web": "cd apps/web && npm run dev",
    "dev:socket": "cd apps/socket-server && npm run dev",
    "install:all": "npm install && npm install --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}